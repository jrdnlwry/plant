{
  "manifest_version": 3,
  "name": "Ambient Plant Companion",
  "description": "A lightweight plant companion overlay for webpages.",
  "version": "0.1.0",
  "action": {
    "default_title": "Plant Companion",
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/weatherService.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/sharedPlantState.js",
        "src/content/injectPlant.js"
      ],
      "css": [
        "src/content/overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*"
  ]
}
