{
  "name": "plant-companion",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "plant-companion",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/extension": {
      "name": "@plant/extension",
      "version": "0.1.0"
    },
    "node_modules/@plant/extension": {
      "resolved": "apps/extension",
      "link": true
    }
  }
}
