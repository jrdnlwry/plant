{
  "name": "plant-companion",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "plant-companion",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/extension": {
      "name": "@plant/extension",
      "version": "0.1.0"
    },
    "node_modules/@plant/extension": {
      "resolved": "apps/extension",
      "link": true
    },
    "node_modules/@plant/plant-core": {
      "resolved": "packages/plant-core",
      "link": true
    },
    "packages/plant-core": {
      "name": "@plant/plant-core",
      "version": "0.1.0"
    },
    "apps/web": {
      "name": "@plant/web",
      "version": "0.1.0",
      "dependencies": {
        "@plant/plant-core": "0.1.0",
        "next": "latest",
        "react": "latest",
        "react-dom": "latest"
      },
      "devDependencies": {
        "@types/node": "latest",
        "@types/react": "latest",
        "@types/react-dom": "latest",
        "typescript": "latest"
      }
    },
    "node_modules/@plant/web": {
      "resolved": "apps/web",
      "link": true
    }
  }
}
